# ---------- 必填 ----------
# 从浏览器导出的 cookies 文件路径（Netscape 格式）
COOKIES_FILE=cookies.txt

# 同步目标，逗号分隔
# 可选值: bookmarks, likes，或直接填推文/用户 URL
# 示例: SYNC_TARGETS=bookmarks,likes
SYNC_TARGETS=bookmarks

# likes 需要填自己的 handle（不含 @）
X_HANDLE=

# 下载目录
DOWNLOAD_DIR=downloads

# ---------- 代理（可选）----------
# 支持 socks5/http 代理
# 示例: PROXY=socks5://127.0.0.1:1080
PROXY=

# ---------- Telegram ----------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
# 默认目标频道（bot/sync 共用）
TELEGRAM_CHAT_ID=
# bot.py 白名单：只响应这些 chat_id，逗号分隔；空则对所有人开放
BOT_ALLOWED_CHAT_IDS=
# bot 并发线程数（gallery-dl 库调用串行，但下载/上传仍可并发）
BOT_MAX_WORKERS=4
# Telegram API 端点。自建 local bot-api 可解锁 2 GB 上传：
#   TELEGRAM_API_BASE=http://127.0.0.1:8081
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_RATE_LIMIT_SECONDS=1.5
TELEGRAM_SEND_RETRIES=3
TELEGRAM_MAX_UPLOAD_BYTES=52428800
TELEGRAM_SPLIT_OVERSIZED_VIDEO=true
TELEGRAM_COMPRESS_OVERSIZED_VIDEO=true
TELEGRAM_FFMPEG_PRESET=veryfast
DELETE_LOCAL_AFTER_TELEGRAM=true

# ---------- 多频道路由（可选）----------
# 把 source chat_id 映射到不同目标频道，例如
#   ROUTES_JSON={"123456789":"-1001111111111","987654321":"-1002222222222"}
ROUTES_JSON=

# ---------- 内置 scheduler ----------
# bot.py 内置定时同步替代 systemd timer，0 = 关闭
SYNC_INTERVAL_MINUTES=60
# 订阅扫描间隔（/subscribe @user 用），0 = 关闭
SUBSCRIPTION_INTERVAL_MINUTES=60

# ---------- 去重 & 配额 ----------
# bot 模式下，同一 URL 在该时间内不重复处理
URL_DEDUP_TTL_DAYS=7
# 媒体 md5 去重（同一图片多次出现只发一次）
MEDIA_HASH_DEDUP=true
# 下载目录上限（GB），超过时按 mtime 清理；0 = 不限
DOWNLOAD_DIR_MAX_GB=0

# ---------- 日志 ----------
LOG_FILE=data/bot.log
LOG_LEVEL=INFO

# ---------- Webhook 模式（可选，留空则用 long polling）----------
# 公网 https URL，例如 https://example.com（Telegram 必须能直接访问）
WEBHOOK_URL=
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_PATH=/tg/webhook
# 自定义 secret_token，防止伪造请求
WEBHOOK_SECRET=

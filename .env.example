# ---------- 必填 ----------
# 从浏览器导出的 cookies 文件路径（Netscape 格式）
COOKIES_FILE=cookies.txt

# 同步目标，逗号分隔
# 可选值: bookmarks, likes，或直接填推文/用户 URL
# 示例: SYNC_TARGETS=bookmarks,likes
#       SYNC_TARGETS=https://x.com/someone/likes
SYNC_TARGETS=bookmarks

# likes 需要填自己的 handle（不含 @）
X_HANDLE=

# 下载目录
DOWNLOAD_DIR=downloads

# ---------- 代理（可选）----------
# 支持 socks5/http 代理
# 示例: PROXY=socks5://127.0.0.1:1080
PROXY=

# ---------- Telegram（可选）----------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
# 媒体发送目标（频道/群组 chat_id）
# sync.py 和 bot.py 都用此项作为推送目的地
TELEGRAM_CHAT_ID=
# bot.py 白名单：只响应这些 chat_id，逗号分隔；空则对所有人开放
# 获取方式: 给 bot 发消息后看终端日志里的 chat_id=xxxxx
BOT_ALLOWED_CHAT_IDS=
# bot.py 并发下载线程数
BOT_MAX_WORKERS=4
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_RATE_LIMIT_SECONDS=1.5
TELEGRAM_SEND_RETRIES=3
TELEGRAM_MAX_UPLOAD_BYTES=52428800
TELEGRAM_SPLIT_OVERSIZED_VIDEO=true
TELEGRAM_COMPRESS_OVERSIZED_VIDEO=true
TELEGRAM_FFMPEG_PRESET=veryfast
DELETE_LOCAL_AFTER_TELEGRAM=false
